DATABASE_URL="postgresql://postgres:postgres@localhost:5432/digital_talk?schema=public"
REDIS_URL=redis://localhost:6379
REALTIME_SESSION_TTL_SECONDS=900
PROVIDER_SECRET_KEY=

# mock | openai-compatible
LLM_PROVIDER=mock
DEFAULT_LLM_BASE_URL=
DEFAULT_LLM_API_KEY=
DEFAULT_LLM_MODEL=

# mock | openai-compatible | openai | custom-http | bailian-cosyvoice
TTS_PROVIDER=mock
# bailian-cosyvoice default: wss://dashscope.aliyuncs.com/api-ws/v1/inference
DEFAULT_TTS_BASE_URL=
DEFAULT_TTS_API_KEY=
DEFAULT_TTS_MODEL=cosyvoice-v3-flash
DEFAULT_TTS_VOICE=longxiaochun
DEFAULT_TTS_FORMAT=mp3
DEFAULT_TTS_SAMPLE_RATE=22050
TTS_CACHE_ENABLED=true

# mock | openai-compatible | openai | custom-http | dashscope-asr | local
ASR_PROVIDER=mock
DEFAULT_ASR_BASE_URL=
DEFAULT_ASR_API_KEY=
DEFAULT_ASR_MODEL=whisper-1
DEFAULT_ASR_LANGUAGE=zh
DEFAULT_ASR_FORMAT=wav
DEFAULT_ASR_SAMPLE_RATE=16000

# Local no-cost avatar generation placeholder
DEFAULT_AVATAR_GENERATION_IMAGE=marketing/beautiful_girl.png

# disabled | mock | remote
COMFYUI_PROVIDER=disabled
COMFYUI_MOCK=false
COMFYUI_BASE_URL=
COMFYUI_API_KEY=
COMFYUI_WORKFLOW_ID=

NEXT_PUBLIC_APP_URL=http://localhost:3000
