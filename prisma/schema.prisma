generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ConversationStatus {
  active
  archived
  deleted
}

enum MessageRole {
  user
  assistant
  system
  tool
}

enum MessageStatus {
  pending
  streaming
  completed
  failed
  interrupted
}

enum ProviderType {
  llm
  tts
  asr
  embedding
  avatar
}

enum TestStatus {
  success
  failed
}

enum KnowledgeBaseStatus {
  active
  disabled
  deleted
}

enum DocumentStatus {
  uploaded
  parsing
  chunked
  embedded
  failed
}

enum PromptType {
  system
  chat
  summary
  translate
  custom
}

enum PromptStatus {
  active
  disabled
  deleted
}

enum AvatarDriver {
  static
  live2d
  vrm
}

enum AvatarProfileStatus {
  active
  disabled
  deleted
}

model User {
  id                    String           @id @default(cuid())
  name                  String?
  email                 String?          @unique
  avatarUrl             String?
  conversations         Conversation[]
  knowledgeBases        KnowledgeBase[]
  providerConfigs       ProviderConfig[]
  avatarProfiles        AvatarProfile[]
  promptTemplates       PromptTemplate[]
  createdPromptVersions PromptVersion[]  @relation("PromptVersionsCreatedBy")
  appSettings           AppSetting[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model Conversation {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  summary         String?
  status          ConversationStatus @default(active)
  modelProviderId String?
  knowledgeBaseId String?
  knowledgeBase   KnowledgeBase?     @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)
  lastMessageAt   DateTime?
  isStarred       Boolean            @default(false)
  archivedAt      DateTime?
  deletedAt       DateTime?
  messages        Message[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId])
  @@index([knowledgeBaseId])
  @@index([lastMessageAt])
  @@index([isStarred])
  @@index([archivedAt])
  @@index([status])
}

model Message {
  id              String        @id @default(cuid())
  conversationId  String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            MessageRole
  content         String
  status          MessageStatus @default(completed)
  metadata        Json?
  parentMessageId String?
  parentMessage   Message?      @relation("MessageBranches", fields: [parentMessageId], references: [id])
  childMessages   Message[]     @relation("MessageBranches")
  audioUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
}

model KnowledgeBase {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  status        KnowledgeBaseStatus @default(active)
  documentCount Int                 @default(0)
  chunkCount    Int                 @default(0)
  conversations Conversation[]
  documents     Document[]
  chunks        DocumentChunk[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
  @@index([status])
}

model Document {
  id              String          @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  name            String
  originalName    String
  mimeType        String
  size            Int
  storageKey      String
  status          DocumentStatus  @default(uploaded)
  errorMessage    String?
  chunkCount      Int             @default(0)
  chunks          DocumentChunk[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([knowledgeBaseId])
  @@index([status])
}

model DocumentChunk {
  id              String        @id @default(cuid())
  documentId      String
  document        Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  content         String
  tokenCount      Int?
  chunkIndex      Int
  embedding       Json?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([knowledgeBaseId])
}

model ProviderConfig {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            ProviderType
  provider        String
  name            String
  enabled         Boolean      @default(true)
  baseUrl         String?
  apiKeyEncrypted String?
  model           String?
  options         Json?
  lastTestStatus  TestStatus?
  lastTestAt      DateTime?
  avatarProfiles  AvatarProfile[] @relation("AvatarProviderConfig")
  voiceProfiles   AvatarProfile[] @relation("AvatarVoiceProviderConfig")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([type])
  @@index([enabled])
}

model AvatarProfile {
  id               String              @id @default(cuid())
  userId           String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  driver           AvatarDriver        @default(static)
  providerConfigId String?
  providerConfig   ProviderConfig?     @relation("AvatarProviderConfig", fields: [providerConfigId], references: [id], onDelete: SetNull)
  voiceProviderId  String?
  voiceProvider    ProviderConfig?     @relation("AvatarVoiceProviderConfig", fields: [voiceProviderId], references: [id], onDelete: SetNull)
  voice            String?
  language         String?
  background       String?
  previewImageUrl  String?
  config           Json?
  isDefault        Boolean             @default(false)
  status           AvatarProfileStatus @default(active)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([userId])
  @@index([driver])
  @@index([status])
  @@index([isDefault])
}

model PromptTemplate {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             PromptType
  name             String
  description      String?
  currentVersionId String?         @unique
  currentVersion   PromptVersion?  @relation("CurrentPromptVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions         PromptVersion[] @relation("PromptTemplateVersions")
  variables        Json?
  status           PromptStatus    @default(active)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([userId, type, name])
  @@index([userId])
  @@index([type])
  @@index([status])
}

model PromptVersion {
  id               String          @id @default(cuid())
  promptTemplateId String
  promptTemplate   PromptTemplate  @relation("PromptTemplateVersions", fields: [promptTemplateId], references: [id], onDelete: Cascade)
  currentFor       PromptTemplate? @relation("CurrentPromptVersion")
  version          Int
  content          String
  variables        Json?
  changelog        String?
  createdByUserId  String?
  createdBy        User?           @relation("PromptVersionsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())

  @@unique([promptTemplateId, version])
  @@index([promptTemplateId])
  @@index([createdByUserId])
}

model AppSetting {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}
